<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= mix.title %> — <%= site.djName %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="site-header">
    <div class="shell">
      <a class="brand" href="/"><img class="logo-mark" src="/img/logo.png" alt="<%= site.djName %>"></a>
    </div>
  </header>

  <div class="shell">
    <div class="detail-wrap">
      <div>
        <div class="detail-cover">
          <% if (mix.cover_filename) { %>
            <img src="/uploads/covers/<%= mix.cover_filename %>" alt="<%= mix.title %>">
          <% } %>
        </div>
        <% if (mix.preview_filename) { %>
          <audio class="preview-player" controls src="/uploads/mixes/<%= mix.preview_filename %>"></audio>
        <% } %>
      </div>

      <div>
        <div class="detail-eyebrow"><%= mix.duration_label || 'Full mix' %></div>
        <h1><%= mix.title %></h1>
        <p class="detail-desc"><%= mix.description %></p>

        <div class="checkout-box">
          <div class="tip-heading">Name your tip — every shilling supports the next mix.</div>

          <div class="tip-grid" id="tip-grid">
            <div class="tip-option" data-amount="50" onclick="selectTip(50, this)">
              <span class="tip-amt">50</span><span class="tip-tag">Bless</span>
            </div>
            <div class="tip-option" data-amount="100" onclick="selectTip(100, this)">
              <span class="tip-amt">100</span><span class="tip-tag">Support</span>
            </div>
            <div class="tip-option" data-amount="200" onclick="selectTip(200, this)">
              <span class="tip-amt">200</span><span class="tip-tag">Sow big</span>
            </div>
          </div>

          <div class="tip-custom-row">
            <span class="currency-prefix"><%= site.currency %></span>
            <input type="number" id="custom-tip" min="<%= mix.price %>" placeholder="Or enter your own amount"
