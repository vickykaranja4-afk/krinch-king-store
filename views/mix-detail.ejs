<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= mix.title %> — <%= site.djName %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="site-header">
    <div class="shell">
      <a class="brand" href="/"><img class="logo-mark" src="/img/logo.png" alt="<%= site.djName %>"></a>
    </div>
  </header>

  <div class="shell">
    <div class="detail-wrap">
      <div>
        <div class="detail-cover">
          <% if (mix.cover_filename) { %>
            <img src="/uploads/covers/<%= mix.cover_filename %>" alt="<%= mix.title %>">
          <% } %>
        </div>
        <% if (mix.preview_filename) { %>
          <audio class="preview-player" controls src="/uploads/mixes/<%= mix.preview_filename %>"></audio>
        <% } %>
      </div>

      <div>
        <div class="detail-eyebrow"><%= mix.duration_label || 'Full mix' %></div>
        <h1><%= mix.title %></h1>
        <p class="detail-desc"><%= mix.description %></p>

        <div class="checkout-box">
          <div class="tip-heading">Name your tip — every shilling supports the next mix.</div>

          <div class="tip-grid" id="tip-grid">
            <div class="tip-option" data-amount="50" onclick="selectTip(50, this)">
              <span class="tip-amt">50</span><span class="tip-tag">Bless</span>
            </div>
            <div class="tip-option" data-amount="100" onclick="selectTip(100, this)">
              <span class="tip-amt">100</span><span class="tip-tag">Support</span>
            </div>
            <div class="tip-option" data-amount="200" onclick="selectTip(200, this)">
              <span class="tip-amt">200</span><span class="tip-tag">Sow big</span>
            </div>
          </div>

          <div class="tip-custom-row">
            <span class="currency-prefix"><%= site.currency %></span>
            <input type="number" id="custom-tip" min="<%= mix.price %>" placeholder="Or enter your own amount" oninput="selectCustomTip()">
          </div>
          <div class="tip-min-note">Minimum tip <span class="min-amt"><%= site.currency %> <%= mix.price %></span> to unlock the download.</div>

          <div class="pay-method-tabs">
            <button type="button" class="pay-method-tab active" id="method-mpesa" onclick="selectMethod('mpesa')">M-Pesa</button>
            <button type="button" class="pay-method-tab" id="method-card" onclick="selectMethod('card')">Card</button>
          </div>

          <div id="checkout-form">
            <div class="field" id="phone-field">
              <label for="phone">M-Pesa phone number</label>
              <input type="tel" id="phone" placeholder="07XX XXX XXX" autocomplete="tel">
              <div class="field-hint">You'll get a prompt on your phone to enter your M-Pesa PIN.</div>
            </div>
            <button class="btn btn-block" id="pay-btn" onclick="startCheckout()">Tip &amp; download</button>
          </div>

          <div id="status" class="status-message"></div>
        </div>
      </div>
    </div>
  </div>

  <footer class="site-footer">
    <div class="shell">
      <span><%= site.djName %></span>
      <span>Secure M-Pesa checkout</span>
    </div>
  </footer>

  <script>
    const mixId = "<%= mix.id %>";
    const minTip = <%= mix.price %>;
    let selectedTip = null;
    let paymentMethod = 'mpesa';
    let pollTimer = null;

    function selectMethod(method) {
      paymentMethod = method;
      document.getElementById('method-mpesa').classList.toggle('active', method === 'mpesa');
      document.getElementById('method-card').classList.toggle('active', method === 'card');
      document.getElementById('phone-field').style.display = method === 'mpesa' ? '' : 'none';
      document.getElementById('pay-btn').textContent = method === 'mpesa' ? 'Tip & download' : 'Continue to card payment';
    }

    function selectTip(amount, el) {
      selectedTip = amount;
      document.querySelectorAll('.tip-option').forEach(o => o.classList.remove('selected'));
      el.classList.add('selected');
      document.getElementById('custom-tip').value = '';
    }

    function selectCustomTip() {
      const val = parseInt(document.getElementById('custom-tip').value, 10);
      selectedTip = isNaN(val) ? null : val;
      document.querySelectorAll('.tip-option').forEach(o => o.classList.remove('selected'));
    }

    function showStatus(type, message) {
      const el = document.getElementById('status');
      el.className = 'status-message show ' + type;
      el.textContent = message;
    }

    async function startCheckout() {
      if (!selectedTip || selectedTip < minTip) {
        showStatus('failed', 'Choose or enter a tip of at least ' + minTip + ' to continue.');
        return;
      }

      if (paymentMethod === 'card') {
        await startCardCheckout();
        return;
      }

      const phone = document.getElementById('phone').value.trim();
      if (!phone) {
        showStatus('failed', 'Enter your M-Pesa phone number first.');
        return;
      }

      const btn = document.getElementById('pay-btn');
      btn.disabled = true;
      btn.textContent = 'Sending prompt...';
      showStatus('pending', 'Starting payment request...');

      try {
        const res = await fetch('/api/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ mixId, phoneNumber: phone, amount: selectedTip }),
        });
        const data = await res.json();

        if (!res.ok) {
          showStatus('failed', data.error || 'Could not start payment.');
          btn.disabled = false;
          btn.textContent = 'Tip & download';
          return;
        }

        showStatus('pending', 'Check your phone — enter your M-Pesa PIN to complete payment.');
        btn.textContent = 'Waiting for payment...';
        pollPaymentStatus(data.orderId);
      } catch (err) {
        showStatus('failed', 'Network error. Please try again.');
        btn.disabled = false;
        btn.textContent = 'Tip & download';
      }
    }

    async function startCardCheckout() {
      const btn = document.getElementById('pay-btn');
      btn.disabled = true;
      btn.textContent = 'Redirecting...';
      showStatus('pending', 'Taking you to secure card checkout...');

      try {
        const res = await fetch('/api/checkout/card', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ mixId, amount: selectedTip }),
        });
        const data = await res.json();

        if (!res.ok) {
          showStatus('failed', data.error || 'Could not start card payment.');
          btn.disabled = false;
          btn.textContent = 'Continue to card payment';
          return;
        }

        window.location.href = data.checkoutUrl;
      } catch (err) {
        showStatus('failed', 'Network error. Please try again.');
        btn.disabled = false;
        btn.textContent = 'Continue to card payment';
      }
    }

    function pollPaymentStatus(orderId) {
      let attempts = 0;
      const maxAttempts = 40; // ~2 minutes at 3s interval

      pollTimer = setInterval(async () => {
        attempts++;
        try {
          const res = await fetch('/api/checkout/status/' + orderId);
          const data = await res.json();

          if (data.status === 'paid') {
            clearInterval(pollTimer);
            showStatus('paid', 'Payment received! Your download is starting...');
            document.getElementById('pay-btn').textContent = 'Paid ✓';
            // Trigger automatic download
            window.location.href = data.downloadUrl;
          } else if (data.status === 'failed') {
            clearInterval(pollTimer);
            showStatus('failed', 'Payment failed or was cancelled. Please try again.');
            const btn = document.getElementById('pay-btn');
            btn.disabled = false;
            btn.textContent = 'Tip & download';
          } else if (attempts >= maxAttempts) {
            clearInterval(pollTimer);
            showStatus('failed', 'Payment timed out. If you completed it on your phone, refresh this page.');
            const btn = document.getElementById('pay-btn');
            btn.disabled = false;
            btn.textContent = 'Tip & download';
          }
        } catch (err) {
          // keep trying silently on transient network errors
        }
      }, 3000);
    }

    // If returning from a card payment redirect, auto-check status
    const urlParams = new URLSearchParams(window.location.search);
    const returningOrderId = urlParams.get('order');
    if (returningOrderId) {
      showStatus('pending', 'Confirming your card payment...');
      document.getElementById('pay-btn').disabled = true;
      pollPaymentStatus(returningOrderId);
    }
  </script>
</body>
</html>
